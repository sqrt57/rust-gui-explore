{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-text-editor",
  "version": "0.1.0",
  "identifier": "com.example.tauri-text-editor",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "tauri-text-editor",
        "width": 900,
        "height": 650,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
